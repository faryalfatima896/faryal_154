<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Faryal Fatima | My Personal Space</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #fdf8f0;
      font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
      line-height: 1.5;
      color: #2c2b2e;
      padding: 1.5rem;
    }

    .site-container {
      max-width: 1100px;
      margin: 0 auto;
      background: white;
      border-radius: 2rem;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
      overflow: hidden;
    }

    header {
      background: #ffffff;
      border-bottom: 1px solid #f0e7db;
      padding: 1.2rem 2rem;
    }

    .logo-area {
      font-size: 1.7rem;
      font-weight: 600;
      background: linear-gradient(135deg, #b46b5c, #d68b7a);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      margin-bottom: 0.8rem;
    }

    nav {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 0.5rem;
    }

    .nav-btn {
      background: none;
      border: none;
      font-size: 1rem;
      font-weight: 500;
      padding: 0.5rem 1.2rem;
      cursor: pointer;
      border-radius: 40px;
      transition: all 0.2s;
      color: #4a3b2f;
    }

    .nav-btn:hover {
      background: #f9ede3;
    }

    .nav-btn.active {
      background: #b46b5c;
      color: white;
    }

    .page-content {
      padding: 2rem 2rem 2.5rem;
      min-height: 65vh;
    }

    .card-info {
      background: #fffaf5;
      border-radius: 1.5rem;
      padding: 1.8rem;
      border: 1px solid #f3e5d9;
    }

    .fixed-profile {
      border-left: 6px solid #d68b7a;
    }

    .posts-grid {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
      margin-top: 1rem;
    }

    .post-preview {
      background: #ffffff;
      border: 1px solid #f0e2d6;
      border-radius: 1.2rem;
      padding: 1.2rem 1.5rem;
      cursor: pointer;
      transition: all 0.2s;
    }

    .post-preview:hover {
      background: #fefaf5;
      border-color: #d4b9a8;
      transform: translateX(3px);
    }

    .post-title {
      font-size: 1.4rem;
      font-weight: 600;
      color: #8b5a4a;
      margin-bottom: 0.3rem;
    }

    .post-meta {
      font-size: 0.8rem;
      color: #9b7b6a;
      margin-bottom: 0.6rem;
    }

    .full-post-view {
      background: #fffdf9;
      border-radius: 1.5rem;
      padding: 1rem 0;
    }

    .back-btn {
      background: none;
      border: none;
      color: #b46b5c;
      font-weight: 500;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 1.5rem;
      padding: 0.4rem 0.8rem;
      border-radius: 30px;
    }

    .back-btn:hover {
      background: #f9ede3;
    }

    .full-post-title {
      font-size: 2rem;
      font-weight: 700;
      color: #6b3f2f;
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 500px;
      margin-top: 1rem;
    }

    .contact-form input, .contact-form textarea {
      padding: 0.8rem;
      border-radius: 1rem;
      border: 1px solid #e2cfc0;
      font-family: inherit;
      background: white;
    }

    .contact-form button {
      background: #b46b5c;
      color: white;
      border: none;
      padding: 0.7rem;
      border-radius: 2rem;
      font-weight: 600;
      cursor: pointer;
      width: 140px;
    }

    .hidden-page {
      display: none;
    }

    .inline-message {
      margin-top: 0.8rem;
      font-size: 0.85rem;
      color: #5a7a4a;
    }

    footer {
      background: #fdf7f0;
      border-top: 1px solid #f0e2d6;
      text-align: center;
      padding: 1.2rem;
      font-size: 0.8rem;
      color: #8b6d5c;
    }

    @media (max-width: 680px) {
      body {
        padding: 0.8rem;
      }
      .page-content {
        padding: 1.2rem;
      }
    }
  </style>
</head>
<body>
<div class="site-container">
  <header>
    <div class="logo-area">🌸 Faryal Fatima | Personal Space</div>
    <nav>
      <button class="nav-btn active" data-page="index">🏠 Home</button>
      <button class="nav-btn" data-page="about">📖 About</button>
      <button class="nav-btn" data-page="contact">✉️ Contact</button>
      <button class="nav-btn" data-page="blog">📝 Blog</button>
    </nav>
  </header>

  <div class="page-content">
    <!-- INDEX PAGE: fixed info about Faryal Fatima, NO posts -->
    <div id="index-page" class="page">
      <div class="card-info fixed-profile">
        <h2>✨ Assalam-o-Alaikum, I'm Faryal Fatima</h2>
        <p style="margin-top: 12px;"><strong>🌸 fixed information about me</strong></p>
        <p>I'm a thoughtful soul who loves writing, creativity, and finding beauty in small moments. This is my personal corner on the internet — no crowded posts on the first page, just a warm introduction to who I am.</p>
        <hr>
        <p>📍 Based in Karachi, Pakistan<br>
        📚 Currently reading: "Mushaf" and poetry by Parveen Shakir<br>
        ☕ Favorite ritual: chai + journaling at dusk<br>
        🌱 Building a life filled with intention & kindness.</p>
        <p style="margin-top: 10px; font-style: italic;">— Index page: fixed information about me, no blog posts here. 🤍</p>
      </div>
    </div>

    <!-- ABOUT PAGE -->
    <div id="about-page" class="page hidden-page">
      <div class="card-info">
        <h2>📖 About Me & This Website</h2>
        <p>I'm Faryal Fatima — a writer, dreamer, and someone who believes in the power of words. I created this website to have a quiet space where my thoughts can live peacefully.</p>
        <p>This site has exactly 4 pages: Home (with fixed info about me), About, Contact, and Blog. On the blog page you'll find short reflections — click any title to read the full post.</p>
        <p>Thank you for visiting my little world. May you find something that stays with you. 🤍</p>
      </div>
    </div>

    <!-- CONTACT PAGE -->
    <div id="contact-page" class="page hidden-page">
      <div class="card-info">
        <h2>✉️ Contact Me</h2>
        <p>I'd love to hear from you — whether it's a question, a kind word, or just a hello.</p>
        <div class="contact-form">
          <input type="text" id="contact-name" placeholder="Your name">
          <input type="email" id="contact-email" placeholder="Your email">
          <textarea rows="3" id="contact-msg" placeholder="Write your message..."></textarea>
          <button id="send-contact-btn">Send message</button>
          <div id="form-feedback" class="inline-message"></div>
        </div>
      </div>
    </div>

    <!-- BLOG PAGE -->
    <div id="blog-page" class="page hidden-page">
      <div id="blog-list-view">
        <h2>📝 My personal reflections</h2>
        <p style="margin-bottom: 1rem;">Click on any post to read the full story.</p>
        <div id="posts-container" class="posts-grid"></div>
      </div>
      <div id="blog-full-view" class="full-post-view hidden-page">
        <button id="back-to-posts" class="back-btn">← Back to all posts</button>
        <div id="full-post-content"></div>
      </div>
    </div>
  </div>
  <footer>
    © 2025 Faryal Fatima — a quiet space with 4 pages. Home page has fixed info, no posts. Blog shows excerpts & full posts on click.
  </footer>
</div>

<script>
  // Blog posts — Faryal Fatima ke khud ke posts
  const postsData = [
    {
      id: 1,
      title: "Chai aur tanhai: ek subah",
      date: "March 28, 2025",
      snippet: "Jab saans rukti hai aur pyali garam ho, tab alag hi sukoon milta hai...",
      content: "Aaj subah uthi to mausam thanda tha. Main ne chai banai aur khidki ke paas baith gayi. Tanhai ajeeb cheez hai — kabhi daraati hai, kabhi apni lagti hai. Is subah tanhai ne mujhe apna dost samajh liya. Maine apni diary mein likha: 'Jo log tumhe samajhte hain, unki kami nahi hoti. Jo samajhna chahte hain, woh mil jaate hain.' Yeh post un lamhon ke liye hai jab hum sirf apne saath hote hain, aur woh waqt khubsurat ho jaata hai."
    },
    {
      id: 2,
      title: "Wo khat jo maine kabhi nahi bheja",
      date: "March 15, 2025",
      snippet: "Har insaan ke paas ek khat hota hai jo likh kar kisi ko nahi deta...",
      content: "Maine ek dost ko khat likha tha. Usme likha tha: 'Tumhari yaad ab dard nahi deti, bas ek geet ki tarah bajti hai.' Woh khat aaj bhi mere drawer mein hai. Kabhi kabhi sochti hoon, jo baatein hum keh nahi paate, woh zyada sacchi hoti hain. Shayad isiliye hum unhein kagaz par utaar dete hain aur phir chupa lete hain. Tumhara bhi koi khat hai jo kabhi bheja nahi? Use padho aaj — sirf apne liye."
    },
    {
      id: 3,
      title: "Kitabon se dosti",
      date: "March 5, 2025",
      snippet: "Kitaab woh dost hai jo kabhi thakta nahi, kabhi jhooth nahi bolta...",
      content: "Jab main chhoti thi, Ammi kehti thin 'kitab teri sabse achi saheli banegi.' Aur woh sahi kehti thin. Maine dosti ki, rishtey nibhaye, lekin kitaabon ne kabhi dhoka nahi diya. Har kitaab ek naya jahan hai. Is hafte maine 'Peer-e-Kamil' dubara parhi — har baar naya sabq milta hai. Agar aap akela mehsoos karein, to koi kitaab utha lijiye. Woh aapse baat karegi."
    },
    {
      id: 4,
      title: "Khud se milne ka safar",
      date: "February 20, 2025",
      snippet: "Insaan sab se mushkil safar apne andar ki taraf karta hai...",
      content: "Pichle saal maine khud ko dhundhna shuru kiya. Logo ko khush karne ki aadat thi, apni sunni chhod di thi. Phir ek din main ne likhna shuru kiya — apne liye. Woh din badal gaya. Aaj main apni aankhon mein dekhti hoon to ek larki milti hai jo mushkilon ke baad bhi hansti hai. Yeh post un sab ke liye jo apne aapse dubara milna chahte hain. Rasta mushkil hai, lekin akhir mein tumhe khud miloge. Aur woh milan sab se khoobsurat hota hai."
    }
  ];

  const pages = {
    index: document.getElementById('index-page'),
    about: document.getElementById('about-page'),
    contact: document.getElementById('contact-page'),
    blog: document.getElementById('blog-page')
  };

  const navBtns = document.querySelectorAll('.nav-btn');
  const postsContainer = document.getElementById('posts-container');
  const blogListView = document.getElementById('blog-list-view');
  const blogFullView = document.getElementById('blog-full-view');
  const fullPostContentDiv = document.getElementById('full-post-content');
  const backBtn = document.getElementById('back-to-posts');

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  function renderPostList() {
    if (!postsContainer) return;
    postsContainer.innerHTML = '';
    postsData.forEach(post => {
      const previewDiv = document.createElement('div');
      previewDiv.className = 'post-preview';
      previewDiv.setAttribute('data-post-id', post.id);
      previewDiv.innerHTML = `
        <div class="post-title">📖 ${escapeHtml(post.title)}</div>
        <div class="post-meta">📅 ${escapeHtml(post.date)}</div>
        <div class="post-snippet">${escapeHtml(post.snippet)}</div>
      `;
      previewDiv.addEventListener('click', () => showFullPost(post.id));
      postsContainer.appendChild(previewDiv);
    });
  }

  function showFullPost(postId) {
    const post = postsData.find(p => p.id === postId);
    if (!post) return;
    fullPostContentDiv.innerHTML = `
      <div class="full-post-title">${escapeHtml(post.title)}</div>
      <div class="full-post-meta" style="color:#9b7b6a; margin-bottom:1rem;">📅 ${escapeHtml(post.date)} · ✍️ Faryal Fatima</div>
      <div class="full-post-body">${escapeHtml(post.content).replace(/\n/g, '<br>')}</div>
    `;
    blogListView.classList.add('hidden-page');
    blogFullView.classList.remove('hidden-page');
  }

  function resetToBlogList() {
    blogListView.classList.remove('hidden-page');
    blogFullView.classList.add('hidden-page');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function switchToPage(pageId) {
    Object.keys(pages).forEach(key => {
      if (pages[key]) pages[key].classList.add('hidden-page');
    });
    if (pages[pageId]) pages[pageId].classList.remove('hidden-page');

    navBtns.forEach(btn => {
      const btnPage = btn.getAttribute('data-page');
      if (btnPage === pageId) btn.classList.add('active');
      else btn.classList.remove('active');
    });

    if (pageId === 'blog') {
      resetToBlogList();
      if (postsContainer && postsContainer.children.length === 0) renderPostList();
    }
  }

  renderPostList();

  navBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const page = btn.getAttribute('data-page');
      if (page && pages[page]) switchToPage(page);
    });
  });

  if (backBtn) backBtn.addEventListener('click', resetToBlogList);

  // Contact form
  const sendBtn = document.getElementById('send-contact-btn');
  const feedbackDiv = document.getElementById('form-feedback');
  if (sendBtn) {
    sendBtn.addEventListener('click', () => {
      const name = document.getElementById('contact-name')?.value.trim();
      const email = document.getElementById('contact-email')?.value.trim();
      const msg = document.getElementById('contact-msg')?.value.trim();
      if (!name || !email || !msg) {
        feedbackDiv.innerHTML = '❌ Please fill all fields.';
        feedbackDiv.style.color = '#b13e3e';
        setTimeout(() => { feedbackDiv.innerHTML = ''; }, 2500);
        return;
      }
      if (!email.includes('@')) {
        feedbackDiv.innerHTML = '⚠️ Please enter a valid email.';
        feedbackDiv.style.color = '#b13e3e';
        setTimeout(() => { feedbackDiv.innerHTML = ''; }, 2500);
        return;
      }
      feedbackDiv.innerHTML = '✨ Thank you, Faryal will reply soon! 🤍';
      feedbackDiv.style.color = '#5a7a4a';
      document.getElementById('contact-name').value = '';
      document.getElementById('contact-email').value = '';
      document.getElementById('contact-msg').value = '';
      setTimeout(() => { feedbackDiv.innerHTML = ''; }, 3000);
    });
  }

  switchToPage('index');
</script>
</body>
</html>
